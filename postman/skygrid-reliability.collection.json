{
  "info": {
    "name": "Aura Sky / SKYGRID Reliability Checks",
    "description": "Baseline Postman/Newman checks for the Aura Sky / SKYGRID by Aura-Core static launch site and public status JSON.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Aura Sky SKYGRID Site Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{site_url}}",
          "host": ["{{site_url}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const siteBody = pm.response.text();",
              "const siteBodyLower = siteBody.toLowerCase();",
              "",
              "pm.test('Status code is successful', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204, 301, 302]);",
              "});",
              "",
              "pm.test('Response time is under 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "pm.test('Response body is not empty', function () {",
              "    pm.expect(siteBody).to.be.a('string').and.to.have.length.above(0);",
              "});",
              "",
              "pm.test('Response contains Aura Sky / SKYGRID launch copy', function () {",
              "    pm.expect(siteBodyLower.includes('skygrid')).to.equal(true);",
              "    pm.expect(siteBodyLower.includes('aura-core')).to.equal(true);",
              "    pm.expect(siteBodyLower.includes('pilot')).to.equal(true);",
              "});",
              "",
              "pm.collectionVariables.set('last_status_code', pm.response.code);",
              "pm.collectionVariables.set('last_response_time_ms', pm.response.responseTime);",
              "pm.collectionVariables.set('last_checked_at', new Date().toISOString());",
              "pm.collectionVariables.set('last_url', pm.request.url.toString());"
            ]
          }
        }
      ]
    },
    {
      "name": "Public Status JSON",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/status/health.json",
          "host": ["{{base_url}}"],
          "path": ["status", "health.json"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const statusText = pm.response.text().trim();",
              "const statusContentType = pm.response.headers.get('Content-Type') || '';",
              "let statusJson = null;",
              "",
              "pm.test('Status JSON loads successfully', function () {",
              "    pm.expect(pm.response.code).to.equal(200);",
              "});",
              "",
              "pm.test('Status JSON is fast', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "pm.test('Status JSON response is JSON, not an HTML error page', function () {",
              "    pm.expect(statusText.startsWith('{')).to.equal(true);",
              "    pm.expect(statusText.startsWith('<')).to.equal(false);",
              "    statusJson = JSON.parse(statusText);",
              "    pm.expect(statusJson).to.be.an('object');",
              "});",
              "",
              "pm.test('Status JSON confirms emergency health ACK and pilot/demo mode', function () {",
              "    if (!statusJson) { statusJson = JSON.parse(statusText); }",
              "    pm.expect(statusJson.ack).to.equal(true);",
              "    pm.expect(statusJson.nack).to.equal(false);",
              "    pm.expect(statusJson.code).to.equal('ACK_OK');",
              "    pm.expect(statusJson.project).to.include('SKYGRID');",
              "    pm.expect(statusJson.claims_mode).to.equal('pilot_demo_only');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Optional AWS Service Health Endpoint",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{aws_service_url}}/status/health.json",
          "host": ["{{aws_service_url}}"],
          "path": ["status", "health.json"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Optional AWS/static mirror status is acceptable', function () {",
              "    pm.expect([200, 204, 404, 503]).to.include(pm.response.code);",
              "});",
              "pm.test('Optional AWS/static mirror response time is under 5000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "site_url",
      "value": "https://mvpuknowme.github.io/Aura-core/"
    },
    {
      "key": "base_url",
      "value": "https://mvpuknowme.github.io/Aura-core"
    },
    {
      "key": "aws_service_url",
      "value": "https://mvpuknowme.github.io/Aura-core"
    }
  ]
}
