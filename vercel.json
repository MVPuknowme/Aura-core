{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/health.json",
      "destination": "/api/health"
    },
    {
      "source": "/",
      "destination": "/api/index"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.3.6-b12-ingress"
        }
      ]
    }
  ]
}
