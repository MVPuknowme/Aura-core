{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.2.0"
        }
      ]
    }
  ]
}
