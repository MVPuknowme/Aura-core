{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "rm -rf node_modules ~/.local/share/pnpm/store && corepack enable && corepack prepare pnpm@10.23.0 --activate && pnpm config set registry https://registry.npmjs.org/ && pnpm run preflight:interference && pnpm install --frozen-lockfile=false",
  "buildCommand": "corepack enable && corepack prepare pnpm@10.23.0 --activate && pnpm run build",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/runtime"
    },
    {
      "source": "/health.json",
      "destination": "/api/runtime"
    },
    {
      "source": "/dispatch",
      "destination": "/api/runtime"
    },
    {
      "source": "/scenarios",
      "destination": "/api/runtime"
    },
    {
      "source": "/rates",
      "destination": "/api/runtime"
    },
    {
      "source": "/base",
      "destination": "/api/runtime"
    },
    {
      "source": "/pay",
      "destination": "/api/runtime"
    },
    {
      "source": "/highway",
      "destination": "/api/runtime"
    },
    {
      "source": "/interface",
      "destination": "/api/interface-page"
    },
    {
      "source": "/api/pay/quote",
      "destination": "/api/runtime"
    },
    {
      "source": "/api/highway/status",
      "destination": "/api/runtime"
    },
    {
      "source": "/api/highway/flasks",
      "destination": "/api/runtime"
    },
    {
      "source": "/api/highway/postman",
      "destination": "/api/runtime"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.3.4-public-interface"
        }
      ]
    }
  ]
}
