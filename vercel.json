{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": null,
  "functions": {
    "app.js": {
      "runtime": "nodejs24.x"
    }
  },
  "rewrites": [
    {
      "source": "/health.json",
      "destination": "/app.js"
    },
    {
      "source": "/api/health",
      "destination": "/app.js"
    },
    {
      "source": "/api/device-status",
      "destination": "/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/app.js"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.3.0-runtime"
        }
      ]
    }
  ]
}
