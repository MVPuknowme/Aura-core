{
  "version": 2,
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "echo 'SkyGrid static landing ready'",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
