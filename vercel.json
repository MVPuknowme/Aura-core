{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm install --frozen-lockfile=false",
  "buildCommand": "corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm run build",
  "rewrites": [
    {
      "source": "/health.json",
      "destination": "/api/health"
    },
    {
      "source": "/",
      "destination": "/api/home"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-SkyGrid-Network",
          "value": "Aura-Core"
        },
        {
          "key": "X-Phoenix-Version",
          "value": "1.3.9-vercel-home"
        }
      ]
    }
  ]
}
