{
  "name": "aura-core",
  "version": "1.3.0-runtime",
  "private": true,
  "description": "Aura-Core SKYGRID runtime with live health and device status routes.",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "build": "node -e \"console.log('Aura-Core runtime deployment: no static build required')\"",
    "vercel-build": "npm run build",
    "prod": "AURA_MODE=prod SKYGRID_TRACE=false SKYGRID_LEVEL=info NODE_ENV=production node app.js",
    "deploy": "npm run prod",
    "validator:health": "node scripts/validator-health-check.mjs",
    "node:ledger": "node scripts/build-node-ledger.mjs",
    "stripe:expansion-session": "node scripts/create-stripe-expansion-session.mjs",
    "test.config": "npm run build"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "latest",
    "ethers": "latest",
    "stripe": "latest",
    "viem": "latest",
    "wagmi": "latest"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
