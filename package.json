{
  "name": "aura-core",
  "version": "1.3.0-runtime",
  "private": true,
  "description": "Aura-Core SKYGRID runtime with live health and device status routes.",
  "main": "app.js",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "build": "node -e \"console.log('Aura-Core runtime deployment: no static build required')\"",
    "vercel-build": "pnpm run build",
    "prod": "AURA_MODE=prod SKYGRID_TRACE=false SKYGRID_LEVEL=info NODE_ENV=production node app.js",
    "deploy": "pnpm run prod",
    "run.config": "node scripts/skygrid-run-config.mjs",
    "preflight:ai-build": "pnpm run run.config && pnpm run preflight:interference && pnpm run build",
    "preflight:interference": "node scripts/build-interference-preflight.mjs",
    "validator:health": "node scripts/validator-health-check.mjs",
    "node:ledger": "node scripts/build-node-ledger.mjs",
    "stripe:expansion-session": "node scripts/create-stripe-expansion-session.mjs",
    "debug:utility-billing": "node scripts/debug-utility-billing-architecture.mjs",
    "make.debug": "pnpm run debug:utility-billing",
    "test.config": "pnpm run run.config"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "latest",
    "ethers": "latest",
    "stripe": "latest",
    "viem": "latest",
    "wagmi": "latest"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
