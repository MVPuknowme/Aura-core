# Aura-Core / SkyGrid backend + real node data + auth
# Do not commit real secrets.

MVP_ID=MVP-19830312
MVP_NODE=42XA-0312

# Backend dashboard/router
PORT=3000
ROUTER_PORT=4000
SKYGRID_DASHBOARD_URL=http://127.0.0.1:3000/skygrid-status

# Routing targets
SKYGRID_SWITCH_TARGETS=aws-us-east-1-virginia,aws-us-west-2-oregon,aws-us-west-1-california,local-mesh-lapine,meshtastic-lapine
SKYGRID_REGION=aws-us-east-1-virginia

# Allowlisted upstream forwarding only
# Example:
# SKYGRID_UPSTREAMS=aws-us-east-1-virginia=https://your-owned-upstream.example.com,aws-us-west-2-oregon=https://your-owned-oregon-upstream.example.com
SKYGRID_UPSTREAMS=

# AWS real node data
AWS_REGION=us-east-1
# Configure AWS credentials via `aws configure`, IAM role, or secure cloud secret manager.

# Linear auth — set only in secret store or shell. Never commit the real value.
LINEAR_API_KEY=
LINEAR_API_URL=https://api.linear.app/graphql

# Optional integrations
DISCORDBOTLIST_API_BASE=https://discordbotlist.com/api/v1
DISCORDBOTLIST_TOKEN=
