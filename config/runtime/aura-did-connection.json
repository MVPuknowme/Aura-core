{
  "aura_did_connection": {
    "version": 1,
    "name": "Aura Open Protocol DID Check",
    "owner": "Michael Vincent Patrick / MVPuknowme",
    "mode": "pilot_demo_only",
    "base_url": "https://agent.auraopenprotocol.org/check",
    "method": "GET",
    "query_param": "did",
    "did_method": "aura",
    "default_did": "did:aura:mvpuknowme",
    "raw_requested_url": "https://agent.auraopenprotocol.org/check?did=did:aura:",
