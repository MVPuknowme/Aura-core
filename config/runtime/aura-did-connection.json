    },
    "security": {
      "redact_query_in_public_logs": false,
      "no_private_keys_in_url": true,
      "no_seed_phrase_in_url": true,
      "consent_required_for_identity_binding": true
    },
    "status": {
      "configured": true,
      "live_verified": false,
      "last_updated": "2026-05-19",
      "notes": "The user-provided URL ended at did:aura: without a method-specific identifier. The connection is installed with did:aura:mvpuknowme as the safe default test DID."
    }
  }
